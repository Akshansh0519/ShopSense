# ============================================================
# ShopSense API — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# --- API Security ---
# A secret key used to authenticate API requests.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=deea090f049941a28eb0dc742ff515b6d6ea20e09103c24382bc0142d1830ca3

# --- Allowed Origins ---
# Comma-separated list of allowed frontend origins for CORS.
# Use "*" for development only. NEVER use "*" in production.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Environment ---
# Set to "production" to disable Swagger UI (/docs, /redoc)
APP_ENV=development


## You need 2 terminals running simultaneously:

Terminal 1 — FastAPI Backend (the brain)
powershell
.\.venv\Scripts\uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload


Terminal 2 — Frontend UI (the face)
powershell
python -m http.server 3000 --directory frontend
Then open your browser: